#!/usr/bin/env bash
#
# amongus-launcher-maker
#
# Generates a .desktop launcher (plus a small wrapper script) for a modded
# Among Us installation. The launcher asks Steam itself to start the game
# (steam://rungameid/945360) while a shim placed in the game's Launch
# Options swaps in the modded exe — so Steam's Running status, Stop button
# and overlay all behave correctly, and no protontricks/flatpak is needed.
#
# Can be run fully interactively (Zenity dialogs when a GUI is available,
# plain terminal prompts otherwise) or non-interactively via CLI flags —
# see --help. Run it once per modded folder; each run produces its own
# independently named wrapper + .desktop pair.
#
set -euo pipefail

APPID=945360
SHIM_PATH="/usr/lib/amongus-launcher-maker/steam-shim"
LAUNCH_OPTIONS="$SHIM_PATH %command%"
DEFAULT_WRAPPER_DIR="${HOME}/.local/share/amongus-launchers"

# ---------------------------------------------------------------------------
# CLI flags (all optional — anything not given is prompted for)
# ---------------------------------------------------------------------------
EXE_PATH=""
DISPLAY_NAME=""
DESKTOP_FILENAME=""
DESKTOP_DIR=""
WRAPPER_DIR=""
FORCE=0          # overwrite existing wrapper/.desktop without asking
NO_GUI=0         # skip zenity even if available
ASSUME_YES=0     # answer "yes" to warnings (e.g. exe not named Among Us.exe)

usage() {
    cat <<EOF
Usage: amongus-launcher-maker [OPTIONS]

Creates a .desktop launcher for a modded Among Us install. The game is
started through Steam itself (AppID ${APPID}), with a shim swapping in the
modded exe, so Steam tracks the game correctly.

One-time setup: in Steam -> Among Us -> Properties -> Launch Options, set:
  ${LAUNCH_OPTIONS}
(The tool checks for this and reminds you if it is missing.)

Options (anything omitted is asked interactively):
  --exe PATH            Path to the modded "Among Us.exe"
  --name NAME           Display name shown in the menu (e.g. "Town of Us")
  --desktop-file NAME   Filename for the .desktop file (e.g. town-of-us.desktop)
  --desktop-dir DIR     Directory to save the .desktop file in
  --wrapper-dir DIR     Directory to save the wrapper script in
                        (default: ${DEFAULT_WRAPPER_DIR})
  --force               Overwrite existing wrapper/.desktop files
  --yes                 Auto-accept warnings (non-standard exe name, etc.)
  --no-gui              Use terminal prompts even if Zenity is available
  -h, --help            Show this help
EOF
}

while [ $# -gt 0 ]; do
    case "$1" in
        --exe)          EXE_PATH="$2"; shift 2 ;;
        --name)         DISPLAY_NAME="$2"; shift 2 ;;
        --desktop-file) DESKTOP_FILENAME="$2"; shift 2 ;;
        --desktop-dir)  DESKTOP_DIR="$2"; shift 2 ;;
        --wrapper-dir)  WRAPPER_DIR="$2"; shift 2 ;;
        --force)        FORCE=1; shift ;;
        --yes)          ASSUME_YES=1; shift ;;
        --no-gui)       NO_GUI=1; shift ;;
        -h|--help)      usage; exit 0 ;;
        *) echo "Unknown option: $1" >&2; usage >&2; exit 2 ;;
    esac
done

# ---------------------------------------------------------------------------
# Prompt helpers — Zenity when a GUI session is available, terminal otherwise
# ---------------------------------------------------------------------------
have_gui() {
    [ "$NO_GUI" -eq 0 ] && command -v zenity >/dev/null 2>&1 \
        && { [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; }
}

# ask_file <dialog title> -> echoes chosen path
ask_file() {
    local title="$1" path=""
    if have_gui; then
        path=$(zenity --file-selection --title="$title" \
                      --filename="${HOME}/.steam/steam/steamapps/common/" \
                      --file-filter='Among Us.exe | *.exe' \
                      --file-filter='All files | *' 2>/dev/null) || true
    fi
    if [ -z "$path" ]; then
        read -e -r -p "$title: " path
    fi
    printf '%s' "$path"
}

# ask_text <prompt> [default] -> echoes answer
ask_text() {
    local prompt="$1" default="${2:-}" answer=""
    if have_gui; then
        answer=$(zenity --entry --title="amongus-launcher-maker" \
                        --text="$prompt" --entry-text="$default" 2>/dev/null) || true
    fi
    if [ -z "$answer" ]; then
        if [ -n "$default" ]; then
            read -e -r -p "$prompt [$default]: " answer
            answer="${answer:-$default}"
        else
            read -e -r -p "$prompt: " answer
        fi
    fi
    printf '%s' "$answer"
}

# ask_dir <prompt> [default] -> echoes chosen directory
ask_dir() {
    local prompt="$1" default="${2:-}" dir=""
    if have_gui; then
        dir=$(zenity --file-selection --directory --title="$prompt" \
                     ${default:+--filename="$default/"} 2>/dev/null) || true
    fi
    if [ -z "$dir" ]; then
        if [ -n "$default" ]; then
            read -e -r -p "$prompt [$default]: " dir
            dir="${dir:-$default}"
        else
            read -e -r -p "$prompt: " dir
        fi
    fi
    printf '%s' "$dir"
}

# confirm <question> -> exit status 0 = yes
confirm() {
    local question="$1" answer=""
    [ "$ASSUME_YES" -eq 1 ] && return 0
    if have_gui; then
        zenity --question --title="amongus-launcher-maker" --text="$question" 2>/dev/null
        return $?
    fi
    read -r -p "$question [y/N]: " answer
    [[ "$answer" =~ ^[Yy] ]]
}

die() { echo "ERROR: $*" >&2; exit 1; }
info() { echo ">> $*"; }

# ---------------------------------------------------------------------------
# Step 1: verify Steam and the shim are present
# ---------------------------------------------------------------------------
check_steam() {
    command -v steam >/dev/null 2>&1 \
        || die "The 'steam' command was not found. This tool requires a native Steam install."
    [ -e "$SHIM_PATH" ] \
        || die "Shim not found at $SHIM_PATH — reinstall the amongus-launcher-maker package."
    info "Steam and launch shim found."
}

# ---------------------------------------------------------------------------
# Step 2: pick and validate the exe
# ---------------------------------------------------------------------------
get_exe_path() {
    while :; do
        if [ -z "$EXE_PATH" ]; then
            EXE_PATH="$(ask_file "Select the modded Among Us.exe")"
        fi
        [ -n "$EXE_PATH" ] || die "No exe path given."
        # Normalise to an absolute path so the launcher works from anywhere.
        EXE_PATH="$(readlink -f "$EXE_PATH")"

        if [ ! -f "$EXE_PATH" ]; then
            echo "File does not exist: $EXE_PATH" >&2
            EXE_PATH=""
            continue
        fi
        if [ "$(basename "$EXE_PATH")" != "Among Us.exe" ]; then
            if ! confirm "Warning: file is not named \"Among Us.exe\" ($(basename "$EXE_PATH")). Use it anyway?"; then
                EXE_PATH=""
                continue
            fi
        fi
        break
    done
    info "Using exe: $EXE_PATH"
}

# ---------------------------------------------------------------------------
# Step 3: gather launcher metadata (name, filenames, destinations)
# ---------------------------------------------------------------------------
gather_metadata() {
    while [ -z "$DISPLAY_NAME" ]; do
        DISPLAY_NAME="$(ask_text "Display name for this launcher (e.g. Town of Us)")"
    done

    while [ -z "$DESKTOP_FILENAME" ]; do
        DESKTOP_FILENAME="$(ask_text "Filename for the .desktop file (e.g. town-of-us.desktop)")"
    done
    # Be forgiving: append the extension if the user left it off.
    case "$DESKTOP_FILENAME" in
        *.desktop) : ;;
        *) DESKTOP_FILENAME="${DESKTOP_FILENAME}.desktop" ;;
    esac

    while [ -z "$DESKTOP_DIR" ]; do
        DESKTOP_DIR="$(ask_dir "Where should the .desktop file be saved? (e.g. ${HOME}/.local/share/applications or ${HOME}/Desktop)")"
    done
    DESKTOP_DIR="$(readlink -m "$DESKTOP_DIR")"

    if [ -z "$WRAPPER_DIR" ]; then
        WRAPPER_DIR="$(ask_dir "Where should the wrapper script be saved?" "$DEFAULT_WRAPPER_DIR")"
    fi
    WRAPPER_DIR="$(readlink -m "$WRAPPER_DIR")"
}

# ---------------------------------------------------------------------------
# Step 4: generate the wrapper script and the .desktop file
# ---------------------------------------------------------------------------
generate_files() {
    local base wrapper_path desktop_path icon
    base="${DESKTOP_FILENAME%.desktop}"
    wrapper_path="$WRAPPER_DIR/${base}.sh"
    desktop_path="$DESKTOP_DIR/$DESKTOP_FILENAME"

    mkdir -p "$WRAPPER_DIR" "$DESKTOP_DIR"

    for f in "$wrapper_path" "$desktop_path"; do
        if [ -e "$f" ] && [ "$FORCE" -ne 1 ]; then
            confirm "File already exists: $f — overwrite it?" \
                || die "Aborted; pick a different .desktop filename to keep launchers independent."
        fi
    done

    # Wrapper: records which exe the shim should swap in, then asks Steam
    # to launch Among Us. The shim (in the game's Launch Options) does the
    # actual substitution, so Steam tracks the real game process.
    cat > "$wrapper_path" <<EOF
#!/usr/bin/env bash
# Auto-generated by amongus-launcher-maker — do not edit by hand.
# Launches: ${DISPLAY_NAME}
STATE_DIR="\${XDG_CONFIG_HOME:-\$HOME/.config}/amongus-launcher-maker"
mkdir -p "\$STATE_DIR"
printf '%s\n' $(printf '%q' "$EXE_PATH") > "\$STATE_DIR/target"
exec steam steam://rungameid/${APPID}
EOF
    chmod 755 "$wrapper_path"
    info "Wrapper script written: $wrapper_path"

    # Reuse Steam's Among Us icon if the theme has it, otherwise fall back
    # to a generic games icon.
    icon="applications-games"
    if compgen -G "${HOME}/.local/share/icons/hicolor/*/apps/steam_icon_${APPID}.png" > /dev/null; then
        icon="steam_icon_${APPID}"
    fi

    cat > "$desktop_path" <<EOF
[Desktop Entry]
Type=Application
Name=${DISPLAY_NAME}
Comment=Modded Among Us (via Steam, AppID ${APPID})
Exec="${wrapper_path}"
Icon=${icon}
Terminal=false
Categories=Game;
StartupNotify=false
EOF
    chmod 755 "$desktop_path"
    info ".desktop file written: $desktop_path"

    # On Cinnamon/GNOME a .desktop on the Desktop must also be marked
    # trusted before it is clickable; best-effort, harmless elsewhere.
    if command -v gio >/dev/null 2>&1; then
        gio set "$desktop_path" metadata::trusted true 2>/dev/null || true
    fi

    echo
    echo "Done! \"${DISPLAY_NAME}\" is ready:"
    echo "  launcher : $desktop_path"
    echo "  wrapper  : $wrapper_path"
    echo "  exe      : $EXE_PATH"
    echo
    echo "Run this tool again any time to add launchers for other modded folders."
}

# ---------------------------------------------------------------------------
# Step 5: remind about the one-time Launch Options setup if it looks unset
# ---------------------------------------------------------------------------
check_launch_options() {
    # Best-effort scan of Steam's per-user config for our shim. The vdf
    # format is awkward to parse properly; a grep near the appid block is
    # good enough to decide whether to show the reminder.
    local cfg found=0
    for cfg in "$HOME"/.steam/steam/userdata/*/config/localconfig.vdf; do
        [ -f "$cfg" ] || continue
        if grep -A 30 "\"$APPID\"" "$cfg" 2>/dev/null | grep -q "steam-shim"; then
            found=1
            break
        fi
    done
    if [ "$found" -eq 1 ]; then
        info "Among Us Launch Options already contain the shim — all set."
        return
    fi

    local msg="ONE-TIME SETUP still needed:

Open Steam -> Library -> Among Us -> Properties -> Launch Options
and paste exactly:

  ${LAUNCH_OPTIONS}

Without this, your new launcher will start VANILLA Among Us.
(Normal launches from Steam are unaffected and stay vanilla either way.)"
    if have_gui; then
        zenity --info --title="amongus-launcher-maker" --no-wrap --text="$msg" 2>/dev/null || true
    fi
    echo
    echo "$msg"
}

check_steam
get_exe_path
gather_metadata
generate_files
check_launch_options
