#!/usr/bin/env bash
#
# steam-shim — installed at /usr/lib/amongus-launcher-maker/steam-shim
#
# Set this ONCE in Steam -> Among Us -> Properties -> Launch Options:
#
#   /usr/lib/amongus-launcher-maker/steam-shim %command%
#
# Steam then runs this script with the full vanilla launch command as
# arguments. If a launcher generated by amongus-launcher-maker requested a
# modded copy (by writing its exe path to the target file just before
# triggering steam://rungameid/945360), the vanilla exe argument is swapped
# for the modded one and winhttp is overridden so BepInEx loads. With no
# pending target file (normal launches from Steam) the command runs
# completely unchanged, so vanilla keeps working as before.
#
# Because Steam itself launches the game either way, the client tracks the
# real process: the Running status appears and clears correctly, and the
# Stop button works.
#
set -u

STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/amongus-launcher-maker"
TARGET_FILE="$STATE_DIR/target"
LOG_FILE="$STATE_DIR/shim.log"

mkdir -p "$STATE_DIR"
# Fresh log each launch — this is a debugging aid, not an archive.
{
    echo "[$(date '+%F %T')] shim invoked"
    printf 'arg: %s\n' "$@"
} > "$LOG_FILE"

if [ -f "$TARGET_FILE" ]; then
    target="$(cat "$TARGET_FILE")"
    rm -f "$TARGET_FILE"   # consume it so the next plain launch is vanilla
    if [ -f "$target" ]; then
        # BepInEx needs winhttp to load from the game folder first.
        export WINEDLLOVERRIDES="winhttp=n,b${WINEDLLOVERRIDES:+;$WINEDLLOVERRIDES}"
        swapped=0
        args=()
        for a in "$@"; do
            if [ "$swapped" -eq 0 ] && [[ "$a" == *"/Among Us.exe" ]]; then
                a="$target"
                swapped=1
            fi
            args+=("$a")
        done
        if [ "$swapped" -eq 1 ]; then
            echo "launching modded: $target" >> "$LOG_FILE"
            exec "${args[@]}"
        fi
        echo "WARNING: no 'Among Us.exe' argument found; launching vanilla" >> "$LOG_FILE"
    else
        echo "WARNING: target does not exist, launching vanilla: $target" >> "$LOG_FILE"
    fi
fi

echo "launching vanilla" >> "$LOG_FILE"
exec "$@"
